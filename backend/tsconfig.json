
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"] 
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}


// "module": "CommonJS"
